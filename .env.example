# ==========================================
# MTN MoMo Uganda Loan Platform - Configuration
# ==========================================

# MongoDB Connection (REQUIRED)
# Get free MongoDB at https://www.mongodb.com/cloud/atlas
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/Uganda?retryWrites=true&w=majority

# Server Port (default: 10000)
PORT=10000

# Environment
NODE_ENV=development

# ==========================================
# TELEGRAM BOT (OPTIONAL)
# ==========================================
# Get token from @BotFather on Telegram
# Leave empty to run without Telegram bot
SUPER_ADMIN_BOT_TOKEN=

# Super Admin IDs (comma-separated)
SUPER_ADMINS=ADMIN001

# Manager IDs - can create new admin links (comma-separated)
MANAGERS=

# ==========================================
# DEPLOYMENT URL (Required for Telegram bot webhook)
# ==========================================
# Your deployed app URL (no trailing slash)
# Example: https://your-app.onrender.com
RENDER_EXTERNAL_URL=
APP_URL=

# ==========================================
# PAYMENT DETAILS
# ==========================================
# M-Pesa payment details (Okeyo Bungu - 0791336749)
# UGX 10,000 monthly subscription fee
# Admins send payment via M-Pesa then use /payment CODE
